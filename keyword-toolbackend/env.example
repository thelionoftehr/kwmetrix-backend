# ─────────────────────────────────────────────────────────────
#  Keyword Metrix Pro — Environment Variables
#  Copy this file to .env and fill in your real credentials
#  NEVER commit .env to git — it's in .gitignore
# ─────────────────────────────────────────────────────────────

# ── Google Ads API Credentials ────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth2_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_oauth2_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=1234567890

# ── Server Config ─────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS — your frontend domain ───────────────────────────────
# For local dev: http://localhost:5500
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ── Cache TTL (seconds) ───────────────────────────────────────
CACHE_TTL_KEYWORDS=3600
CACHE_TTL_SUGGEST=300
