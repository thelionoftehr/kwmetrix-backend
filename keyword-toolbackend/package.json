'use strict';

const express = require('express');
const router = express.Router();

const { getKeywordData } = require('../services/googleAds');

router.get('/', async (req, res) => {
  try {
    const keyword = req.query.keyword;

    if (!keyword) {
      return res.status(400).json({
        success: false,
        error: 'Keyword is required',
      });
    }

    const data = await getKeywordData(keyword);

    res.json(data);
  } catch (err) {
    console.error(err);

    res.status(500).json({
      success: false,
      error: 'Failed to fetch keyword data from Google Ads API.',
      detail: err.message,
    });
  }
});

module.exports = router;
